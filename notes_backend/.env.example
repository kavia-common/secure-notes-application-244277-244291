# FastAPI Secure Notes App (.env.example)
# Copy this file to .env and fill the values for your environment.

# Database connection
POSTGRES_URL=localhost                       # Database host URL, e.g. db.example.com
POSTGRES_USER=your_user                      # PostgreSQL username
POSTGRES_PASSWORD=your_password              # PostgreSQL password
POSTGRES_DB=notes_db                         # Main database name
POSTGRES_PORT=5432                           # Typical PostgreSQL port

# Auth/JWT config
JWT_SECRET_KEY=your-secret-key               # Change to secure random value!
JWT_ALGORITHM=HS256                          # Algorithm type for JWT (do not change unless needed)
